{
    "name": "Homelab Dev Ops",
    "build": { 
        "dockerfile": "Dockerfile" 
    },
    "containerEnv": {
        // Pulls your token from your Mac's shell env into the container
        "OP_SERVICE_ACCOUNT_TOKEN": "${localEnv:OP_SERVICE_ACCOUNT_TOKEN}"
    },
    "mounts": [
        // Bridge: Mac Docker Socket -> Container Docker Socket
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "redhat.vscode-yaml",
                "1Password.op-vscode"
            ],
            "settings": {
                "1Password.op-vscode.account": "my", 
                "1Password.op-vscode.vault": "rita-v4",
                "terminal.integrated.defaultProfile.linux": "zsh"
            }
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "chmod +x scripts/**/*.sh && echo 'source /workspaces/rita-v4/.labrc' >> ~/.zshrc && echo 'alias pan-up=\"/workspaces/rita-v4/scripts/1-session/06-pangolin-up.sh\"' >> ~/.zshrc",
    "postStartCommand": "sudo chmod 666 /var/run/docker.sock"
}
